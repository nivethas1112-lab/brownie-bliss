# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/brownie_bliss

# JWT Secrets (generate your own secure keys)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRE=30d

# Admin Credentials (for initial admin user)
ADMIN_EMAIL=admin@browniebliss.com
ADMIN_PASSWORD=admin123

# File Upload
UPLOAD_PATH=./server/src/uploads
MAX_FILE_SIZE=5000000

# CORS
CLIENT_URL=http://localhost:5173

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
